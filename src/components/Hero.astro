---
import TerminalMockup from './TerminalMockup.astro';
---

<section aria-label="Hero">
  <div class="flex flex-col md:flex-row items-center gap-12 min-h-screen px-6 py-24 max-w-7xl mx-auto">
    <!-- Copy panel (DOM-first for mobile stack order: copy above, terminal below) -->
    <div class="w-full md:w-1/2 flex flex-col gap-6">
      <h1 class="text-4xl md:text-5xl font-bold tracking-tight text-slate-100 leading-tight">
        Let your work speak for itself.
      </h1>
      <p class="text-xl text-dcv-accent font-medium">
        The offline, privacy-first, developer focused performance review prep and career reflection tool.
      </p>
      <p class="text-slate-400 leading-relaxed">
        dcv reads your work output and generates structured reports to help you reflect on your performance and prepare for reviews.
        No cloud, no accounts, no data leaving your machine.
      </p>
      <div class="flex flex-col gap-2">
        <span class="text-sm text-slate-400 font-mono uppercase tracking-widest">Install</span>
        <pre class="bg-slate-800 rounded-md px-4 py-3 font-mono text-sm text-dcv-accent overflow-x-auto"><code>curl -fsSL https://apps.microcode.io/dcv/install.sh | sh</code></pre>
      </div>
    </div>
    <!-- Terminal panel -->
    <div class="w-full md:w-1/2">
      <TerminalMockup />
    </div>
  </div>
</section>
