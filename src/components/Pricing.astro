---
interface Props {
  proPrice?: string;    // Default: "[PRICE]"
}

interface PricingFeature {
  text: string;
  annotation?: string;
}

interface PricingTier {
  name: string;
  price: string;
  features: PricingFeature[];
  ctaLabel: string;
  ctaHref?: string;
}

const { proPrice = "[PRICE]" } = Astro.props;

const tiers: PricingTier[] = [
  {
    name: "Free",
    price: "Free",
    features: [
      { text: "GitHub repositories (public & private)" },
      { text: "Trello boards" },
      { text: "Local Git repositories" },
      { text: "AI-powered analysis & comparison (Anthropic)" },
      { text: "Markdown, HTML & LaTeX export" },
    ],
    ctaLabel: "Install Free",
    ctaHref: `${import.meta.env.BASE_URL}/docs/installation`,
  },
  {
    name: "Pro",
    price: proPrice,
    features: [
      { text: "dcv query — Interactive RAG" },
      { text: "Journal — ad-hoc work logging", annotation: "coming Phase 2" },
      { text: "Enterprise sources: Jira, Linear, GitLab, Azure DevOps", annotation: "planned" },
      { text: "All minor updates & patches for v1.x.x" },
    ],
    ctaLabel: "Buy Pro",
  },
];
---

<section aria-label="Pricing" class="py-16 px-6">
  <h2 class="text-2xl font-semibold text-slate-100 text-center mb-10">Simple, Transparent Pricing</h2>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
    {tiers.map((tier) => (
      <div class={`rounded-lg p-8 min-w-0 overflow-hidden flex flex-col ${tier.name === "Pro" ? "bg-slate-800 border border-dcv-accent/50" : "bg-slate-800 border border-slate-700"}`}>
        <h3 class="text-xl font-bold text-slate-100 mb-2">{tier.name}</h3>
        {tier.name === "Pro" ? (
          <div class="mb-6">
            <div class="flex items-baseline gap-2.5 mb-2">
              <p class="text-3xl font-bold text-dcv-accent">{tier.price}</p>
              <span class="text-xs text-slate-500 line-through">after beta</span>
            </div>
            <span class="bg-dcv-accent/10 text-dcv-accent text-xs px-2.5 py-1 rounded font-medium">
              Unavailable During Beta
            </span>
          </div>
        ) : (
          <p class="text-3xl font-bold text-dcv-accent mb-6">{tier.price}</p>
        )}
        <ul class="space-y-2 mb-6 flex-1">
          {tier.features.map((feature) => (
            <li class="flex items-start gap-2 text-slate-300 text-sm">
              <span class="text-dcv-accent mt-0.5 shrink-0" aria-hidden="true">✓</span>
              <span>
                {feature.text}
                {feature.annotation && (
                  <span class="text-slate-500 text-xs"> ({feature.annotation})</span>
                )}
              </span>
            </li>
          ))}
        </ul>
        {tier.name === "Pro" && (
          <p class="text-xs text-slate-400 mb-6 border-t border-slate-700 pt-4">
            Perpetual License for v1.x.x — includes all minor updates and patches.
          </p>
        )}
        {tier.name === "Free" ? (
          <a href={tier.ctaHref} class="text-center text-dcv-accent underline underline-offset-4 text-sm hover:text-cyan-300 transition-colors">
            {tier.ctaLabel}
          </a>
        ) : (
          <button
            type="button"
            disabled
            aria-disabled="true"
            class="block w-full text-center bg-slate-700 text-slate-500 font-semibold py-3 px-6 rounded-md cursor-not-allowed border border-slate-600"
          >
            Available After Beta
          </button>
        )}
        {tier.name === "Pro" && (
          <div class="border-t border-slate-700 pt-4 mt-5">
            <form id="notify-form" class="space-y-3">
              <p class="text-slate-300 text-sm font-medium">Get notified when Pro launches</p>
              <input
                type="text"
                name="name"
                placeholder="Name (optional)"
                aria-label="Your name"
                class="w-full bg-dcv-bg border border-slate-700 rounded-md px-3 py-2 text-slate-200 text-sm placeholder-slate-500 focus:border-dcv-accent focus:ring-1 focus:ring-dcv-accent focus:outline-none transition-colors"
              />
              <input
                type="email"
                name="email"
                required
                placeholder="Email address"
                aria-label="Email address"
                class="w-full bg-dcv-bg border border-slate-700 rounded-md px-3 py-2 text-slate-200 text-sm placeholder-slate-500 focus:border-dcv-accent focus:ring-1 focus:ring-dcv-accent focus:outline-none transition-colors"
              />
              <button
                type="submit"
                id="notify-btn"
                class="w-full bg-dcv-accent text-dcv-bg font-semibold text-sm py-2.5 px-4 rounded-md hover:bg-dcv-accent/90 transition-colors cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed"
              >
                Notify Me
              </button>
              <p class="text-slate-500 text-xs text-center">No spam. Unsubscribe anytime.</p>
            </form>
            <div id="notify-success" class="hidden text-center py-3" role="status" aria-live="polite">
              <p class="text-dcv-accent text-sm font-medium" tabindex="-1" id="notify-success-msg">You're on the list!</p>
              <p class="text-slate-500 text-xs mt-1">We'll email you when Pro is available.</p>
            </div>
            <noscript>
              <a href="mailto:support@microcode.io?subject=Pro%20Launch%20Notification" class="text-dcv-accent text-xs underline">
                Email us to get notified
              </a>
            </noscript>
          </div>
        )}
      </div>
    ))}
  </div>
</section>

<script is:inline>
(function () {
  var form = document.getElementById('notify-form');
  var btn = document.getElementById('notify-btn');
  var successEl = document.getElementById('notify-success');
  var successMsg = document.getElementById('notify-success-msg');

  if (!form || !btn || !successEl) return;

  form.addEventListener('submit', function (e) {
    e.preventDefault();

    var email = form.querySelector('[name="email"]').value.trim();
    var name = form.querySelector('[name="name"]').value.trim();

    btn.disabled = true;
    btn.textContent = 'Sending...';

    fetch('https://api.microcode.io/dcv/subscribers', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email: email, name: name || undefined }),
    })
      .then(function (res) {
        if (!res.ok) {
          return res.json().catch(function () { return {}; }).then(function (data) {
            throw new Error(data.error || 'Something went wrong. Please try again.');
          });
        }
        form.classList.add('hidden');
        successEl.classList.remove('hidden');
        if (successMsg) successMsg.focus();
      })
      .catch(function (err) {
        var errorEl = document.getElementById('notify-error');
        if (!errorEl) {
          errorEl = document.createElement('p');
          errorEl.id = 'notify-error';
          errorEl.className = 'text-red-400 text-xs mt-2';
          errorEl.setAttribute('role', 'alert');
          form.appendChild(errorEl);
        }
        errorEl.textContent = err.message;
        btn.disabled = false;
        btn.textContent = 'Notify Me';
      });
  });
})();
</script>
