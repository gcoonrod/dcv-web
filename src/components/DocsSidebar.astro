---
interface Props {
  entries: Array<{
    id: string;
    data: { title: string; order: number };
  }>;
  currentSlug: string;
}

const { entries, currentSlug } = Astro.props;

const sectionLabels: Record<string, string> = {
  sources: 'Sources',
  providers: 'Providers',
  guides: 'Guides',
};

// Separate ungrouped (top-level) from grouped (subdirectory) entries
const ungrouped = entries
  .filter((e) => !e.id.includes('/'))
  .sort((a, b) => a.data.order - b.data.order);

const groups = new Map<string, typeof entries>();
for (const entry of entries) {
  if (!entry.id.includes('/')) continue;
  const dir = entry.id.split('/')[0];
  if (!groups.has(dir)) groups.set(dir, []);
  groups.get(dir)!.push(entry);
}

// Sort entries within each group, then sort groups by lowest order
const sortedGroups = [...groups.entries()]
  .map(([dir, items]) => ({
    dir,
    label: sectionLabels[dir] || dir.charAt(0).toUpperCase() + dir.slice(1),
    items: items.sort((a, b) => a.data.order - b.data.order),
  }))
  .sort((a, b) => a.items[0].data.order - b.items[0].data.order);
---

<nav aria-label="Documentation navigation">
  <ul>
    {ungrouped.map((entry) => (
      <li>
        <a
          href={`${import.meta.env.BASE_URL}/docs/${entry.id}`}
          aria-current={entry.id === currentSlug ? 'page' : undefined}
          class={entry.id === currentSlug
            ? 'text-dcv-accent font-bold'
            : 'text-slate-400 hover:text-slate-200 transition-colors'}
        >
          {entry.data.title}
        </a>
      </li>
    ))}
    {sortedGroups.map((group) => (
      <>
        <li class="text-xs text-slate-500 uppercase tracking-wider font-semibold mt-6 mb-2" aria-hidden="true">
          {group.label}
        </li>
        {group.items.map((entry) => (
          <li>
            <a
              href={`${import.meta.env.BASE_URL}/docs/${entry.id}`}
              aria-current={entry.id === currentSlug ? 'page' : undefined}
              class={entry.id === currentSlug
                ? 'text-dcv-accent font-bold'
                : 'text-slate-400 hover:text-slate-200 transition-colors'}
            >
              {entry.data.title}
            </a>
          </li>
        ))}
      </>
    ))}
  </ul>
</nav>
