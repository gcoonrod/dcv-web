---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Open Beta — DCV"
  description="dcv is currently in open beta. Pro license purchases are not yet available."
>
  <section aria-label="Beta notice" class="py-16 px-6 max-w-2xl mx-auto">
    <div class="text-center mb-10">
      <span class="text-dcv-accent text-4xl" aria-hidden="true">&#x1f6a7;</span>
      <h1 class="text-3xl font-bold text-slate-100 mt-4">dcv is in Open Beta</h1>
      <p class="text-slate-400 mt-3 text-base">
        Pro license purchases are not yet available. During the open beta, the Free tier is
        fully available — no account required, no data leaves your machine.
      </p>
    </div>

    <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center text-sm">
      <a
        href={`${import.meta.env.BASE_URL}/docs/installation`}
        class="text-center text-dcv-accent underline underline-offset-4 hover:text-cyan-300 transition-colors"
      >
        Install dcv
      </a>
      <span class="hidden sm:inline text-slate-700" aria-hidden="true">·</span>
      <a
        href={import.meta.env.BASE_URL}
        class="text-center text-slate-400 hover:text-slate-200 transition-colors"
      >
        Return to home
      </a>
    </div>
  </section>
</Layout>
