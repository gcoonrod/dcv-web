---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Purchase Successful — DCV"
  description="Your DCV Pro license purchase was successful. Activate your license key to get started."
>
  <section aria-label="Purchase confirmation" class="py-16 px-6 max-w-2xl mx-auto">
    <div class="text-center mb-10">
      <span class="text-dcv-accent text-4xl" aria-hidden="true">✓</span>
      <h1 class="text-3xl font-bold text-slate-100 mt-4">Thank you for your purchase!</h1>
      <p class="text-slate-400 mt-3 text-base">
        Your DCV Pro license key has been sent to your email address. Check your inbox — it should
        arrive within a few minutes.
      </p>
    </div>

    <div class="bg-slate-800 border border-slate-700 rounded-lg p-8">
      <h2 class="text-lg font-semibold text-slate-100 mb-4">Activate your license</h2>
      <p class="text-slate-300 text-sm mb-4">
        Once you receive your license key by email, run the following command to activate DCV Pro:
      </p>
      <pre class="bg-slate-900 border border-slate-700 rounded-md p-4 overflow-x-auto"><code class="font-mono text-dcv-accent text-sm">dcv activate &lt;your-license-key&gt;</code></pre>
      <p class="text-slate-500 text-xs mt-3">
        Replace <code class="font-mono text-slate-400">&lt;your-license-key&gt;</code> with the key from your purchase email.
      </p>
    </div>

    <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center text-sm">
      <a
        href={`${import.meta.env.BASE_URL}/docs/installation`}
        class="text-center text-dcv-accent underline underline-offset-4 hover:text-cyan-300 transition-colors"
      >
        View installation docs
      </a>
      <span class="hidden sm:inline text-slate-700" aria-hidden="true">·</span>
      <a
        href={import.meta.env.BASE_URL}
        class="text-center text-slate-400 hover:text-slate-200 transition-colors"
      >
        Return to home
      </a>
    </div>
  </section>
</Layout>
