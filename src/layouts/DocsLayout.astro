---
import { getCollection } from 'astro:content';
import Layout from './Layout.astro';
import DocsSidebar from '../components/DocsSidebar.astro';

interface Props {
  title: string;
  description: string;
  currentSlug: string;
}

const { title, description, currentSlug } = Astro.props;

const allDocs = await getCollection('docs');
const sortedEntries = allDocs.sort((a, b) => a.data.order - b.data.order);
---

<Layout title={title} description={description}>
  <div class="flex flex-col md:flex-row min-h-screen">

    <aside class="w-full md:w-64 md:shrink-0 md:sticky md:top-0 md:h-screen md:overflow-y-auto bg-slate-900 border-b md:border-b-0 md:border-r border-slate-800 p-6">
      <DocsSidebar entries={sortedEntries} currentSlug={currentSlug} />
    </aside>

    <!-- Use <div> not <main> — Layout.astro already wraps slot in <main> -->
    <div class="flex-1 min-w-0 overflow-hidden p-6 md:p-12">
      <article class="prose prose-invert max-w-none prose-pre:overflow-x-auto prose-pre:bg-slate-800">
        <slot />
      </article>
    </div>

  </div>
</Layout>
